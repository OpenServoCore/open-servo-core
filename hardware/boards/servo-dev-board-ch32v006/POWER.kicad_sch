	(text_box "Designed to allow powering the system via USB, bench power supply, or LiPo Batteries.\n\nInputs:\n  • VBUS - USB power\n  • VBAT - Battery / Bench power, supports 1S / 2S LiPo Batteries\n\nOutputs:\n• VSYS - primary system rail\n• +3V3 - regulated logic rail\n\nFeatures:\n  • Schottky diode OR-ing\n  • reverse current protection\n  • low quiescent current LDO\n  • rail status indicators"
		(exclude_from_sim no)
		(at 180.34 27.94 0)
		(size 101.6 101.6)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects

	(text_box "Using CH32V006 primarily to reduce cost.\n\nPeripherals used:\n\n  • T1 for center aligned motor PWM (IN1, IN2) and driver enable (EN)\n  • OPA -> PGA -> internal ADC for current sensing (ISNS+, ISNS-)\n  • ADC channels (ISNS+ VPOS, VNTC, VSNS, VSNA, VSNB, ENCA, ENCB)\n  • UART for classic DXL TTL implementation (TX, RX, TX_EN)\n  • Status and debug pins (STAT, DBG)\n  • Debugger (SWDIO)\n\nNote: nRST is sacrificed for differential OPA, which is the heart of this board."
		(exclude_from_sim no)
		(at 172.72 29.21 0)
		(size 109.22 35.56)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.75 1.75)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "420d38a1-53bd-4343-97a5-b28333868320")
	)
